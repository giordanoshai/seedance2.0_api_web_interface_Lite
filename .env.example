# ==================== 阿里云 OSS 配置 ====================
OSS_KEY_ID=
OSS_ACCESSKEY=
OSS_BUCKET_NAME=
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com 
OSS_URI=

# ==================== 火山引擎 / Seedance 配置 ====================
