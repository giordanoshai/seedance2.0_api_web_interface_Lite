# ==================== 火山引擎 / Seedance 配置（必填）====================
SEEDANCE20_KEY=你的Seedance2.0专属KEY
SEEDANCE20_URL=https://ark.cn-beijing.volces.com/api/v3
VM_SEEDANCE_20=doubao-seedance-2-0-260128

# ==================== 阿里云 OSS 配置（可选）====================
# 不填则自动进入「本地模式」：参考图片以 base64 传给 API，无需任何云存储。
# 本地模式限制：不支持参考视频和参考音频，仅支持参考图片。
# 填写以下三项即可启用 OSS 模式，解锁全部参考素材类型（图片 + 视频 + 音频）。
OSS_KEY_ID=
OSS_ACCESSKEY=
OSS_BUCKET_NAME=
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_URI=your-bucket.oss-cn-shanghai.aliyuncs.com

# ==================== 其他配置（保持默认即可）====================
LIMIT_SEEDANCE_20=10
SQLITE_DB_PATH=data/app.db
OUTPUT_DIR=outputs
